# ============================================================
# CultBot configuration
# Copy this file to `.env` and fill in your details.
# ============================================================

# --- Authentication (REQUIRED) ---
# Easiest method: open https://www.cult.fit in your browser and log in.
# Open DevTools (F12) > Network tab > refresh the page > right-click any
# request to cult.fit > "Copy" > "Copy as cURL". Paste it below as ONE line.
CURL_COMMAND=

# --- Alternative to CURL_COMMAND: set the cookies directly ---
# COOKIES=
# API_KEY=
# APP_VERSION=7
# BROWSER_NAME=Chrome
# OS_NAME=browser
# TIMEZONE=Asia/Kolkata

# --- Booking preferences ---
# Your gym's center ID. Find it with:  npm run list-centers
PREFERRED_CENTER=

# Time slots to try, in order (comma-separated). Find with:  npm run list-slots
PREFERRED_SLOTS=07:00:00,08:00:00

# Workouts to book, in priority order (comma-separated).
# The bot tries the first one, then falls back to the next.
# Find the exact names with:  npm run list-workouts
PREFERRED_WORKOUTS=HRX WORKOUT

# Join the waitlist when a class is full (true/false).
ENABLE_WAITLIST=true

# Which day to book: last (default, the newest bookable day) | first | a day id.
# BOOK_DATE=last

# --- Behaviour (all optional) ---
# DRY_RUN=false
# MAX_RETRIES=3
# RETRY_DELAY=1000
# LOG_LEVEL=info

# --- Notifications (all optional; set any you want to use) ---
# DISCORD_WEBHOOK_URL=
# SLACK_WEBHOOK_URL=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# NOTIFY_WEBHOOK_URL=
